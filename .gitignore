# Godot 4.6.3 web export + engine + caches
/.godot/
/out/
/godot
*.tmp

# Binary assets are reconstructed by ./fetch_assets.sh (CDN library assets + the two
# Meshy-generated .glb) so the repo stays lean. Run it once after cloning, then --import.
/models/*.glb
/models/*.glb.import
/audio/*.ogg
/audio/*.ogg.import
/audio/*.wav
/audio/*.wav.import

# in-container tooling (never part of the game)
/verify/
/playbooks/

# Godot script UID caches (regenerated on import) + asset-gen provenance
*.uid
/models/*.jsonl

# world.json is GENERATED by tools/gen_world.py (kept out of git; run it before building)
/world.json
